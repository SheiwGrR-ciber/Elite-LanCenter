<Page x:Class="EliteLanCenter.Pages.ReportesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgPrincipalBrush}"
      FontFamily="{StaticResource InterFont}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- ── Encabezado ─────────────────── -->
            <Border CornerRadius="12" Padding="20"
                    Margin="0 0 0 16" Background="{DynamicResource BgPanelBrush}">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Generar Reporte de Turno"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="LblInfoTurno"
                                   Text="Cargando..."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0 4 0 0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- ── Columna izquierda ───────── -->
                <StackPanel Grid.Column="0" Margin="0 0 16 0">

                    <!-- Resumen ventas -->
                    <Border CornerRadius="12" Padding="20"
                            Margin="0 0 0 16" Background="{DynamicResource BgPanelBrush}">
                        <StackPanel>
                            <TextBlock Text="Resumen de Ventas del Turno"
                                       FontFamily="{StaticResource MontserratFont}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0 0 0 12"/>

                            <!-- Encabezado tabla -->
                            <Border CornerRadius="6" Padding="12 8"
                                    Background="{DynamicResource BgCardBrush}" Margin="0 0 0 4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Producto"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="Cant."
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Total"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <ItemsControl x:Name="ListaResumenVentas">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12 8"
                                                BorderThickness="0 0 0 1">
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="#2D3250"
                                                                 Opacity="0.3"/>
                                            </Border.BorderBrush>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Producto}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Cantidad}"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Total, StringFormat='S/ {0:F2}'}"
                                                           FontSize="13"
                                                           Foreground="#01EFAC"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Total productos -->
                            <Border Padding="12 10" CornerRadius="6"
                                    Background="{DynamicResource BgCardBrush}" Margin="0 8 0 0">
                                <Grid>
                                    <TextBlock Text="Total en Productos:"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="LblTotalProductos"
                                               Text="S/ 0.00"
                                               FontFamily="{StaticResource MontserratFont}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#01EFAC"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Imágenes evidencia -->
                    <Border CornerRadius="12" Padding="20"
                            Background="{DynamicResource BgPanelBrush}">
                        <StackPanel>
                            <TextBlock Text="Imágenes de Evidencia"
                                       FontFamily="{StaticResource MontserratFont}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0 0 0 16"/>

                            <!-- PanCafe 1 -->
                            <TextBlock Text="📷 Captura PanCafe Pro (1):"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0 0 0 6"/>
                            <Grid Margin="0 0 0 12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="8"
                                        Background="{DynamicResource BgCardBrush}" Padding="12 10"
                                        Margin="0 0 8 0">
                                    <TextBlock x:Name="LblImagenPanCafe1"
                                               Text="Sin imagen — Ctrl+V para pegar"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Border>
                                <Button Grid.Column="1"
                                        Content="📁 Importar"
                                        Style="{StaticResource OutlineButton}"
                                        Width="100"
                                        Click="BtnImportarPanCafe1_Click"/>
                            </Grid>

                            <!-- PanCafe 2 -->
                            <TextBlock Text="📷 Captura PanCafe Pro (2):"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0 0 0 6"/>
                            <Grid Margin="0 0 0 12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="8"
                                        Background="{DynamicResource BgCardBrush}" Padding="12 10"
                                        Margin="0 0 8 0">
                                    <TextBlock x:Name="LblImagenPanCafe2"
                                               Text="Sin imagen — Ctrl+V para pegar"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Border>
                                <Button Grid.Column="1"
                                        Content="📁 Importar"
                                        Style="{StaticResource OutlineButton}"
                                        Width="100"
                                        Click="BtnImportarPanCafe2_Click"/>
                            </Grid>

                            <!-- Yape -->
                            <TextBlock Text="📱 Captura Yape:"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0 0 0 6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="8"
                                        Background="{DynamicResource BgCardBrush}" Padding="12 10"
                                        Margin="0 0 8 0">
                                    <TextBlock x:Name="LblImagenYape"
                                               Text="Sin imagen — Ctrl+V para pegar"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Border>
                                <Button Grid.Column="1"
                                        Content="📁 Importar"
                                        Style="{StaticResource OutlineButton}"
                                        Width="100"
                                        Click="BtnImportarYape_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Columna derecha ─────────── -->
                <StackPanel Grid.Column="1">

                    <!-- Formulario -->
                    <Border CornerRadius="12" Padding="20"
                            Margin="0 0 0 16" Background="{DynamicResource BgPanelBrush}">
                        <StackPanel>
                            <TextBlock Text="Datos del Informe"
                                       FontFamily="{StaticResource MontserratFont}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0 0 0 16"/>

                            <!-- Ingreso máquinas -->
                            <TextBlock Text="💻 Ingreso Máquinas (PanCafe):"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0 0 0 6"/>
                            <TextBox x:Name="TxtIngresoMaquinas"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="0.00"
                                     Margin="0 0 0 12"/>

                            <!-- Descuentos -->
                            <TextBlock Text="🎁 Descuentos:"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0 0 0 6"/>
                            <TextBox x:Name="TxtDescuentos"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="0.00"
                                     Margin="0 0 0 12"/>

                            <!-- Yape -->
                            <TextBlock Text="📱 Monto en Yape:"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0 0 0 6"/>
                            <TextBox x:Name="TxtMontoYape"
                                     Style="{StaticResource ModernTextBox}"
                                     Text="0.00"
                                     Margin="0 0 0 16"/>

                            <!-- Resumen calculado -->
                            <Border CornerRadius="8" Padding="12"
                                    Background="{DynamicResource BgPrincipalBrush}" Margin="0 0 0 16">
                                <StackPanel>
                                    <Grid Margin="0 0 0 6">
                                        <TextBlock Text="Total Bruto:"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="LblTotalBruto"
                                                   Text="S/ 0.00"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0 0 0 6">
                                        <TextBlock Text="Descuentos:"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="LblDescuentos"
                                                   Text="S/ 0.00"
                                                   FontSize="12"
                                                   Foreground="#EF4444"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0 0 0 6">
                                        <TextBlock Text="Total Líquido:"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="LblTotalLiquido"
                                                   Text="S/ 0.00"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#01EFAC"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0 0 0 6">
                                        <TextBlock Text="Monto Yape:"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock x:Name="LblMontoYape"
                                                   Text="S/ 0.00"
                                                   FontSize="12"
                                                   Foreground="#2082A6"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border Height="1" Background="{DynamicResource BgCardBrush}"
                                            Margin="0 4"/>
                                    <Grid>
                                        <TextBlock Text="Efectivo a entregar:"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock x:Name="LblEfectivo"
                                                   Text="S/ 0.00"
                                                   FontFamily="{StaticResource MontserratFont}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="#01EFAC"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Botón calcular -->
                            <Button Content="🔢 Calcular"
                                    Style="{StaticResource OutlineButton}"
                                    Click="BtnCalcular_Click"
                                    Margin="0 0 0 8"/>

                            <!-- Mensaje -->
                            <TextBlock x:Name="LblMensaje"
                                       Text=""
                                       FontSize="12"
                                       Foreground="#EF4444"
                                       TextWrapping="Wrap"
                                       Margin="0 0 0 12"/>

                            <!-- Botón generar PDF -->
                            <Button Content="📄 Generar PDF"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnGenerarPDF_Click"
                                    Margin="0 0 0 8"/>

                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>