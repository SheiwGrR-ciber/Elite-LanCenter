<Page x:Class="EliteLanCenter.Pages.AdministracionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#111827"
      FontFamily="{StaticResource InterFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Administración"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#E8EAF6"/>
                <TextBlock x:Name="LblInfo"
                           Text="Gestión de usuarios del sistema"
                           FontSize="13"
                           Foreground="#8892B0"
                           Margin="0 4 0 0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="➕ Nuevo Usuario"
                    Style="{StaticResource AccentButton}"
                    Click="BtnNuevoUsuario_Click"
                    Padding="16 10"/>
        </Grid>

        <!-- Contenido -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Lista de usuarios -->
            <Border Grid.Column="0" CornerRadius="12" Background="#1A1F35" Margin="0 0 16 0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Buscador -->
                    <Border Grid.Row="0" Padding="16">
                        <Border CornerRadius="8" Background="#2D3250">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         x:Name="TxtBuscar"
                                         Height="40"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#E8EAF6"
                                         CaretBrush="#01EFAC"
                                         FontSize="13"
                                         VerticalContentAlignment="Center"
                                         TextChanged="TxtBuscar_TextChanged"/>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- Lista -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaUsuarios">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16 12"
                                            BorderThickness="0 0 0 1"
                                            BorderBrush="#2D3250">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar -->
                                            <Border Grid.Column="0"
                                                    Width="36" Height="36"
                                                    CornerRadius="18"
                                                    Background="#524094">
                                                <TextBlock Text="{Binding Iniciales}"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12 0 0 0">
                                                <TextBlock Text="{Binding Nombre}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#E8EAF6"/>
                                                <TextBlock Text="{Binding UserName}"
                                                           FontSize="11"
                                                           Foreground="#8892B0"/>
                                            </StackPanel>

                                            <!-- Rol -->
                                            <Border Grid.Column="2"
                                                    CornerRadius="4"
                                                    Padding="8 4"
                                                    Margin="8 0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#524094"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EsAdminDueno}" Value="True">
                                                                <Setter Property="Background" Value="#EF4444"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding EsAdminEncargado}" Value="True">
                                                                <Setter Property="Background" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding RolDescripcion}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>
                                            </Border>

                                            <!-- Acciones -->
                                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                                <Button Content="✏️"
                                                        Tag="{Binding Id}"
                                                        Width="32" Height="32"
                                                        Background="#52409420"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="Editar usuario"
                                                        Click="BtnEditar_Click"
                                                        Margin="0 0 4 0"/>
                                                <Button Content="🔑"
                                                        Tag="{Binding Id}"
                                                        Width="32" Height="32"
                                                        Background="#F59E0B20"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="Cambiar contraseña"
                                                        Click="BtnCambiarContrasena_Click"
                                                        Margin="0 0 4 0"/>
                                                <Button Content="🗑️"
                                                        Tag="{Binding Id}"
                                                        Width="32" Height="32"
                                                        Background="#EF444420"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="Eliminar usuario"
                                                        Click="BtnEliminar_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Panel derecho - Info del sistema -->
            <StackPanel Grid.Column="1">
                <!-- Info del sistema -->
                <Border CornerRadius="12" Background="#1A1F35" Padding="20" Margin="0 0 0 16">
                    <StackPanel>
                        <TextBlock Text="📊 Estadísticas del Sistema"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#E8EAF6"
                                   Margin="0 0 0 16"/>

                        <Border CornerRadius="8" Background="#2D3250" Padding="12" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Usuarios" Foreground="#8892B0" FontSize="12"/>
                                <TextBlock Grid.Column="1" x:Name="LblTotalUsuarios" Text="0" FontSize="14" FontWeight="Bold" Foreground="#01EFAC"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="8" Background="#2D3250" Padding="12" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Admins" Foreground="#8892B0" FontSize="12"/>
                                <TextBlock Grid.Column="1" x:Name="LblTotalAdmins" Text="0" FontSize="14" FontWeight="Bold" Foreground="#EF4444"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="8" Background="#2D3250" Padding="12" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Operadores" Foreground="#8892B0" FontSize="12"/>
                                <TextBlock Grid.Column="1" x:Name="LblTotalOperadores" Text="0" FontSize="14" FontWeight="Bold" Foreground="#F59E0B"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="8" Background="#2D3250" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Usuarios Activos" Foreground="#8892B0" FontSize="12"/>
                                <TextBlock Grid.Column="1" x:Name="LblUsuariosActivos" Text="0" FontSize="14" FontWeight="Bold" Foreground="#01EFAC"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Info de la versión -->
                <Border CornerRadius="12" Background="#1A1F35" Padding="20">
                    <StackPanel>
                        <TextBlock Text="ℹ️ Información"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#E8EAF6"
                                   Margin="0 0 0 12"/>

                        <TextBlock Text="Elite LanCenter"
                                   FontSize="13"
                                   Foreground="#E8EAF6"/>
                        <TextBlock Text="Versión 2.0.0"
                                   FontSize="11"
                                   Foreground="#8892B0"
                                   Margin="0 4 0 0"/>
                        <TextBlock Text="Sistema de Gestión Administrativa"
                                   FontSize="11"
                                   Foreground="#8892B0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
