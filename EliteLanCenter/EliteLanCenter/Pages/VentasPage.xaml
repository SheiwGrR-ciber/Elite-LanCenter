<Page x:Class="EliteLanCenter.Pages.VentasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#111827"
      FontFamily="{StaticResource InterFont}">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ── COLUMNA IZQUIERDA — Productos ── -->
        <Grid Grid.Column="0" Margin="0 0 16 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <Border Grid.Row="0" CornerRadius="12"
                    Padding="16" Margin="0 0 0 12"
                    Background="#1A1F35">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Registrar Venta"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#E8EAF6"/>
                        <TextBlock x:Name="LblInfoTurno"
                                   Text="Cargando turno..."
                                   FontSize="12"
                                   Foreground="#8892B0"
                                   Margin="0 4 0 0"/>
                    </StackPanel>

                    <!-- Fiado toggle -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Fiado"
                                   FontSize="13"
                                   Foreground="#8892B0"
                                   VerticalAlignment="Center"
                                   Margin="0 0 8 0"/>
                        <CheckBox x:Name="ChkFiado"
                                  VerticalAlignment="Center"
                                  Foreground="#01EFAC"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lista de productos -->
            <Border Grid.Row="1" CornerRadius="12"
                    Background="#1A1F35">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado tabla -->
                    <Border Grid.Row="0" CornerRadius="8 8 0 0"
                            Padding="16 12" Background="#2D3250">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Producto"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#8892B0"/>
                            <TextBlock Grid.Column="1" Text="Precio"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#8892B0"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Stock"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#8892B0"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Cantidad"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#8892B0"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Acción"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="#8892B0"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Lista scrollable -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaProductos">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16 10"
                                            BorderThickness="0 0 0 1">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#2D3250"
                                                             Opacity="0.5"/>
                                        </Border.BorderBrush>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Nombre}"
                                                       FontSize="13"
                                                       Foreground="#E8EAF6"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding PrecioUnidadFormateado}"
                                                       FontSize="13"
                                                       Foreground="#01EFAC"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StockMostrador}"
                                                       FontSize="13"
                                                       Foreground="#8892B0"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <TextBox Grid.Column="3"
                                                     Tag="{Binding Id}"
                                                     Text="1"
                                                     Width="60"
                                                     Height="32"
                                                     Background="#2D3250"
                                                     Foreground="#E8EAF6"
                                                     BorderBrush="#524094"
                                                     BorderThickness="1"
                                                     TextAlignment="Center"
                                                     HorizontalAlignment="Center"
                                                     VerticalContentAlignment="Center"/>

                                            <Button Grid.Column="4"
                                                    Content="✅ Vender"
                                                    Tag="{Binding Id}"
                                                    Width="100"
                                                    Height="32"
                                                    Style="{StaticResource AccentButton}"
                                                    FontSize="12"
                                                    Click="BtnVender_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ── COLUMNA DERECHA — Panel ventas ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Lista de ventas -->
            <Border Grid.Row="0" CornerRadius="12"
                    Background="#1A1F35" Margin="0 0 0 12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="16 12"
                            Background="#2D3250"
                            CornerRadius="12 12 0 0">
                        <TextBlock Text="Ventas del Turno"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#E8EAF6"/>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="400">
                        <StackPanel x:Name="PanelVentas"
                                    Margin="8"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Fiados pendientes -->
            <Border Grid.Row="1" CornerRadius="12"
                    Background="#1A1F35" Margin="0 0 0 12"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="⏳ Fiados Pendientes"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#F59E0B"
                               Margin="0 0 0 8"/>
                    <ItemsControl x:Name="ListaFiados">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8 6" Margin="0 2"
                                        CornerRadius="6"
                                        Background="#2D3250">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding NombreProducto}"
                                                       FontSize="12"
                                                       Foreground="#E8EAF6"/>
                                            <TextBlock Text="{Binding TotalFormateado}"
                                                       FontSize="11"
                                                       Foreground="#F59E0B"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="✅"
                                                Tag="{Binding Id}"
                                                Width="32" Height="32"
                                                Background="#01EFAC20"
                                                Foreground="#01EFAC"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="BtnPagarFiado_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Total -->
            <Border Grid.Row="2" CornerRadius="12"
                    Padding="16" Background="#1A1F35">
                <StackPanel>
                    <Grid Margin="0 0 0 12">
                        <TextBlock Text="Total del Turno"
                                   FontSize="13"
                                   Foreground="#8892B0"/>
                        <TextBlock x:Name="LblTotal"
                                   Text="S/ 0.00"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#01EFAC"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <TextBlock x:Name="LblMensaje"
                               Text=""
                               FontSize="12"
                               Foreground="#01EFAC"
                               TextWrapping="Wrap"
                               Margin="0 0 0 8"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>