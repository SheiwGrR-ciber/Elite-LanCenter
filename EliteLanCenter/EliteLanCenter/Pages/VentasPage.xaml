<Page x:Class="EliteLanCenter.Pages.VentasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgPrincipalBrush}"
      FontFamily="{StaticResource InterFont}">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- ── COLUMNA 0 — Productos ── -->
        <Grid Grid.Column="0" Margin="0 0 8 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <Border Grid.Row="0" CornerRadius="12"
                    Padding="16" Margin="0 0 0 12"
                    Background="{DynamicResource BgPanelBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Registrar Venta"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="LblInfoTurno"
                                   Text="Cargando turno..."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0 4 0 0"/>
                    </StackPanel>

                    <!-- Fiado toggle -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Fiado"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <CheckBox x:Name="ChkFiado"
                                  VerticalAlignment="Center"
                                  Foreground="#01EFAC"
                                  Margin="4 0 0 0"
                                  Checked="ChkFiado_CheckedChanged"
                                  Unchecked="ChkFiado_CheckedChanged"/>
                        <Border x:Name="PanelNumeroPc"
                                Visibility="Collapsed"
                                CornerRadius="6"
                                Background="{DynamicResource BgCardBrush}"
                                Padding="8 4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PC #"
                                           FontSize="12"
                                           Foreground="#F59E0B"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtNumeroPc"
                                         Width="60"
                                         Height="28"
                                         Margin="4 0 0 0"
                                         FontSize="12"
                                         TextAlignment="Center"
                                         Background="{DynamicResource BgPrincipalBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="#524094"
                                         BorderThickness="1"
                                         VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lista de productos -->
            <Border Grid.Row="1" CornerRadius="12"
                    Background="{DynamicResource BgPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado tabla -->
                    <Border Grid.Row="0" CornerRadius="8 8 0 0"
                            Padding="16 12" Background="{DynamicResource BgCardBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Producto"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="Precio"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Stock"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Cantidad"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Acción"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Lista scrollable -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaProductos">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16 10"
                                            BorderThickness="0 0 0 1">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#2D3250"
                                                             Opacity="0.5"/>
                                        </Border.BorderBrush>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Nombre}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding PrecioUnidadFormateado}"
                                                       FontSize="13"
                                                       Foreground="#01EFAC"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StockMostrador}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <TextBox Grid.Column="3"
                                                     Tag="{Binding Id}"
                                                     Text="1"
                                                     Width="60"
                                                     Height="32"
                                                     Background="{DynamicResource BgCardBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="#524094"
                                                     BorderThickness="1"
                                                     TextAlignment="Center"
                                                     HorizontalAlignment="Center"
                                                     VerticalContentAlignment="Center"/>

                                            <Button Grid.Column="4"
                                                    Content="✅ Vender"
                                                    Tag="{Binding Id}"
                                                    Width="100"
                                                    Height="32"
                                                    Style="{StaticResource AccentButton}"
                                                    FontSize="12"
                                                    Click="BtnVender_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ── COLUMNA 1 — Ventas del Turno + Total ── -->
        <Grid Grid.Column="1" Margin="0 0 8 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Ventas del Turno -->
            <Border Grid.Row="0" CornerRadius="12"
                    Background="{DynamicResource BgPanelBrush}" Margin="0 0 0 12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="16 12"
                            Background="{DynamicResource BgCardBrush}"
                            CornerRadius="12 12 0 0">
                        <TextBlock Text="Ventas del Turno"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanelVentas"
                                    Margin="8"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Total -->
            <Border Grid.Row="1" CornerRadius="12"
                    Padding="16" Background="{DynamicResource BgPanelBrush}">
                <StackPanel>
                    <Grid Margin="0 0 0 12">
                        <TextBlock Text="Total del Turno"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock x:Name="LblTotal"
                                   Text="S/ 0.00"
                                   FontFamily="{StaticResource MontserratFont}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#01EFAC"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <TextBlock x:Name="LblMensaje"
                               Text=""
                               FontSize="12"
                               Foreground="#01EFAC"
                               TextWrapping="Wrap"
                               Margin="0 0 0 8"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── COLUMNA 2 — Fiados Pendientes ── -->
        <Grid Grid.Column="2">
            <Border CornerRadius="12"
                    Background="{DynamicResource BgPanelBrush}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="⏳ Fiados Pendientes"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#F59E0B"
                               Margin="0 0 0 12"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaFiados">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8 6" Margin="0 2"
                                            CornerRadius="6"
                                            Background="{DynamicResource BgCardBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding NombreProducto}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding TotalFormateado}"
                                                           FontSize="11"
                                                           Foreground="#F59E0B"/>
                                                <TextBlock Text="{Binding NumeroPcDisplay}"
                                                           FontSize="10"
                                                           Foreground="#8888B0"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="✅"
                                                    Tag="{Binding Id}"
                                                    Width="32" Height="32"
                                                    Background="#01EFAC20"
                                                    Foreground="#01EFAC"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Click="BtnPagarFiado_Click"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>