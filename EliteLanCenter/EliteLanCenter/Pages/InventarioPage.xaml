<Page x:Class="EliteLanCenter.Pages.InventarioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#111827"
      FontFamily="{StaticResource InterFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Inventario"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#E8EAF6"/>
                <TextBlock x:Name="LblTotalProductos"
                           Text="0 productos en stock"
                           FontSize="13"
                           Foreground="#8892B0"
                           Margin="0 4 0 0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="➕ Nuevo Producto"
                    Style="{StaticResource AccentButton}"
                    Click="BtnNuevoProducto_Click"
                    Padding="16 10"/>
        </Grid>

        <!-- Barra de búsqueda y acciones -->
        <Border Grid.Row="1" CornerRadius="12"
                Padding="16" Margin="0 0 0 16"
                Background="#1A1F35">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="8"
                        Background="#2D3250" Margin="0 0 12 0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 x:Name="TxtBuscar"
                                 Height="40"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#E8EAF6"
                                 CaretBrush="#01EFAC"
                                 FontSize="13"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtBuscar_TextChanged"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="📦 Trasladar a Mostrador"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnTrasladar_Click"
                            Margin="0 0 8 0"/>
                    <Button Content="🔄 Actualizar"
                            Click="BtnActualizar_Click"
                            Padding="16 10"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Lista de productos -->
        <Border Grid.Row="2" CornerRadius="12" Background="#1A1F35">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Encabezado -->
                <Border Grid.Row="0" CornerRadius="12 12 0 0"
                        Padding="16 12" Background="#2D3250">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#"
                                   FontSize="11" FontWeight="Bold" Foreground="#8892B0"/>
                        <TextBlock Grid.Column="1" Text="Producto"
                                   FontSize="11" FontWeight="Bold" Foreground="#8892B0"/>
                        <TextBlock Grid.Column="2" Text="P. Unidad"
                                   FontSize="11" FontWeight="Bold" Foreground="#8892B0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="P. Paq."
                                   FontSize="11" FontWeight="Bold" Foreground="#8892B0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Mostrador"
                                   FontSize="11" FontWeight="Bold" Foreground="#8892B0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="Almacén"
                                   FontSize="11" FontWeight="Bold" Foreground="#8892B0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="Valor Total"
                                   FontSize="11" FontWeight="Bold" Foreground="#8892B0"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="7" Text="Acciones"
                                   FontSize="11" FontWeight="Bold" Foreground="#8892B0"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Lista scrollable -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ListaProductos">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="16 12"
                                        BorderThickness="0 0 0 1">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#2D3250" Opacity="0.5"/>
                                    </Border.BorderBrush>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Id}"
                                                   FontSize="12"
                                                   Foreground="#8892B0"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Nombre}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#E8EAF6"/>
                                            <TextBlock FontSize="11" Foreground="#8892B0">
                                                <Run Text="{Binding UnidadesPaquete, StringFormat={}{0} und/paq}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding PrecioUnidadFormateado}"
                                                   FontSize="12"
                                                   Foreground="#01EFAC"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding PrecioPaqueteFormateado}"
                                                   FontSize="12"
                                                   Foreground="#8892B0"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <Border Grid.Column="4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                CornerRadius="4"
                                                Padding="8 4"
                                                Background="{Binding StockAlertaColor}">
                                            <TextBlock Text="{Binding StockMostrador}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding StockAlertaTexto}"/>
                                        </Border>

                                        <StackPanel Grid.Column="5"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontSize="12" Foreground="#E8EAF6" HorizontalAlignment="Center">
                                                <Run Text="{Binding PaquetesAlmacen}"/>
                                                <Run Text="pkg"/>
                                            </TextBlock>
                                            <TextBlock FontSize="10" Foreground="#8892B0" HorizontalAlignment="Center">
                                                <Run Text="{Binding UnidadesSueltas}"/>
                                                <Run Text="sueltas"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Column="6"
                                                   Text="{Binding ValorTotalFormateado}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#01EFAC"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="7"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center">
                                            <Button Content="✏️"
                                                    Tag="{Binding Id}"
                                                    Width="32" Height="32"
                                                    Background="#52409420"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Editar producto"
                                                    Click="BtnEditar_Click"
                                                    Margin="0 0 4 0"/>
                                            <Button Content="📦"
                                                    Tag="{Binding Id}"
                                                    Width="32" Height="32"
                                                    Background="#01EFAC20"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Trasladar a mostrador"
                                                    Click="BtnTrasladarProducto_Click"
                                                    Margin="0 0 4 0"/>
                                            <Button Content="🗑️"
                                                    Tag="{Binding Id}"
                                                    Width="32" Height="32"
                                                    Background="#EF444420"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Eliminar producto"
                                                    Click="BtnEliminar_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
