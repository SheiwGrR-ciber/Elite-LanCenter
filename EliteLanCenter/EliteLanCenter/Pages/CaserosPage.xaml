<Page x:Class="EliteLanCenter.Pages.CaserosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#111827"
      FontFamily="{StaticResource InterFont}">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- ── COLUMNA IZQUIERDA — Lista caseros ── -->
        <Grid Grid.Column="0" Margin="0 0 16 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Búsqueda -->
            <Border Grid.Row="0" CornerRadius="12"
                    Padding="16" Margin="0 0 0 12"
                    Background="#1A1F35">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="8"
                            Background="#2D3250" Margin="0 0 8 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     x:Name="TxtBuscar"
                                     Height="40"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#E8EAF6"
                                     CaretBrush="#01EFAC"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     TextChanged="TxtBuscar_TextChanged"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="1"
                            Content="➕ Nuevo Casero"
                            Style="{StaticResource AccentButton}"
                            Width="140"
                            Click="BtnNuevoCasero_Click"/>
                </Grid>
            </Border>

            <!-- Lista de caseros -->
            <Border Grid.Row="1" CornerRadius="12"
                    Background="#1A1F35">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado -->
                    <Border Grid.Row="0" CornerRadius="12 12 0 0"
                            Padding="16 12" Background="#2D3250">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cliente"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#8892B0"/>
                            <TextBlock Grid.Column="1" Text="Saldo"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#8892B0"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="RFID"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#8892B0"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Estado"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#8892B0"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Acciones"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="#8892B0"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Lista scrollable -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaCaseros">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16 10"
                                            BorderThickness="0 0 0 1">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#2D3250"
                                                             Opacity="0.5"/>
                                        </Border.BorderBrush>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Nombre -->
                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Nombre}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#E8EAF6"/>
                                                <TextBlock Text="{Binding Apodo}"
                                                           FontSize="11"
                                                           Foreground="#8892B0"/>
                                            </StackPanel>

                                            <!-- Saldo -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SaldoFormateado}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#01EFAC"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <!-- RFID -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TieneRFID, Converter={StaticResource BoolToRFIDConverter}}"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#8892B0"/>

                                            <!-- Estado saldo -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding EstadoSaldo}"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="#8892B0"/>

                                            <!-- Botones -->
                                            <StackPanel Grid.Column="4"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                <Button Content="💰"
                                                        Tag="{Binding Id}"
                                                        Width="32" Height="32"
                                                        Background="#01EFAC20"
                                                        Foreground="#01EFAC"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="Recargar saldo"
                                                        Click="BtnRecargar_Click"
                                                        Margin="0 0 4 0"/>
                                                <Button Content="🎮"
                                                        Tag="{Binding Id}"
                                                        Width="32" Height="32"
                                                        Background="#2082A620"
                                                        Foreground="#2082A6"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        ToolTip="Registrar consumo"
                                                        Click="BtnConsumo_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ── COLUMNA DERECHA — Panel RFID ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Lector RFID -->
            <Border Grid.Row="0" CornerRadius="12"
                    Padding="20" Margin="0 0 0 12"
                    Background="#1A1F35">
                <StackPanel>
                    <TextBlock Text="🏷️ Lector RFID"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#E8EAF6"
                               Margin="0 0 0 12"/>

                    <TextBlock Text="Acerca la tarjeta al lector:"
                               FontSize="12"
                               Foreground="#8892B0"
                               Margin="0 0 0 6"/>

                    <Border CornerRadius="8" Background="#2D3250">
                        <TextBox x:Name="TxtRFID"
                                 Height="42"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#01EFAC"
                                 CaretBrush="#01EFAC"
                                 FontSize="13"
                                 Padding="12 0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtRFID_TextChanged"/>
                    </Border>

                    <!-- Cliente encontrado -->
                    <Border x:Name="PanelClienteRFID"
                            CornerRadius="8" Padding="12"
                            Background="#01EFAC15"
                            Margin="0 12 0 0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock x:Name="LblNombreRFID"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#01EFAC"/>
                            <TextBlock x:Name="LblSaldoRFID"
                                       FontSize="12"
                                       Foreground="#8892B0"
                                       Margin="0 4 0 0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Acciones rápidas -->
            <Border Grid.Row="1" CornerRadius="12"
                    Padding="20" Margin="0 0 0 12"
                    Background="#1A1F35">
                <StackPanel>
                    <TextBlock Text="Acciones Rápidas"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#E8EAF6"
                               Margin="0 0 0 12"/>

                    <TextBlock Text="Monto (S/):"
                               FontSize="12"
                               Foreground="#8892B0"
                               Margin="0 0 0 6"/>

                    <Border CornerRadius="8" Background="#2D3250"
                            Margin="0 0 0 12">
                        <TextBox x:Name="TxtMonto"
                                 Height="42"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#E8EAF6"
                                 CaretBrush="#01EFAC"
                                 FontSize="14"
                                 Padding="12 0"
                                 VerticalContentAlignment="Center"
                                 Text="0.00"/>
                    </Border>

                    <TextBlock x:Name="LblMensaje"
                               Text=""
                               FontSize="12"
                               Foreground="#EF4444"
                               TextWrapping="Wrap"
                               Margin="0 0 0 8"/>

                    <Button Content="💰 Recargar Saldo"
                            Style="{StaticResource AccentButton}"
                            Click="BtnRecargarRapido_Click"
                            Margin="0 0 0 8"/>

                    <Button Content="🎮 Registrar Consumo"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnConsumoRapido_Click"/>
                </StackPanel>
            </Border>

            <!-- Historial -->
            <Border Grid.Row="2" CornerRadius="12"
                    Padding="16" Background="#1A1F35">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Historial"
                               FontFamily="{StaticResource MontserratFont}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#E8EAF6"
                               Margin="0 0 0 8"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ListaHistorial">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8 6" Margin="0 2"
                                            CornerRadius="6"
                                            Background="#2D3250">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding TipoIcono}"
                                                           FontSize="12"
                                                           Foreground="#E8EAF6"/>
                                                <TextBlock Text="{Binding Hora}"
                                                           FontSize="11"
                                                           Foreground="#8892B0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding MontoFormateado}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#01EFAC"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>