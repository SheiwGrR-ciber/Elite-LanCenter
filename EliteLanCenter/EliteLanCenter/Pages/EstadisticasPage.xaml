<Page x:Class="EliteLanCenter.Pages.EstadisticasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgPrincipalBrush}"
      FontFamily="{StaticResource InterFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Reporte Estadístico"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="LblPeriodo"
                           Text="Selecciona un período y genera un reporte Excel"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0 4 0 0"/>
            </StackPanel>
        </Grid>

        <!-- Selector de período y botón generar -->
        <Border Grid.Row="1" CornerRadius="12" Background="{DynamicResource BgPanelBrush}" Padding="24" Margin="0 0 0 20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0 0 24 0">
                    <TextBlock Text="Desde:"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0 0 8 0"/>
                    <DatePicker x:Name="DateDesde"
                                SelectedDate="{x:Static sys:DateTime.Today}"
                                xmlns:sys="clr-namespace:System;assembly=mscorlib"
                                FontSize="13"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Background="{DynamicResource BgCardBrush}"
                                BorderBrush="#2D3250"
                                Width="140"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0 0 24 0">
                    <TextBlock Text="Hasta:"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0 0 8 0"/>
                    <DatePicker x:Name="DateHasta"
                                SelectedDate="{x:Static sys:DateTime.Today}"
                                xmlns:sys="clr-namespace:System;assembly=mscorlib"
                                FontSize="13"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                Background="{DynamicResource BgCardBrush}"
                                BorderBrush="#2D3250"
                                Width="140"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0 0 24 0">
                    <Button Content="7 Días"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnPreset_Click"
                            Tag="7"
                            Margin="0 0 6 0"/>
                    <Button Content="30 Días"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnPreset_Click"
                            Tag="30"
                            Margin="0 0 6 0"/>
                    <Button Content="Este Mes"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnPreset_Click"
                            Tag="mes"/>
                </StackPanel>

                <Button Grid.Column="4"
                        x:Name="BtnGenerarExcel"
                        Content="📥 Generar Excel"
                        Style="{StaticResource AccentButton}"
                        Click="BtnGenerarExcel_Click"
                        Padding="20 10"
                        FontSize="14"
                        FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- Área de estado / info -->
        <Border Grid.Row="2" CornerRadius="12" Background="{DynamicResource BgPanelBrush}" Padding="24">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="📊 Vista previa del reporte a generar"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0 0 0 16"/>

                    <TextBlock x:Name="LblInfo"
                               Text="Selecciona un período y haz clic en Generar Excel para obtener un reporte completo con todos los indicadores."
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>

                    <Border x:Name="PanelResumen"
                            CornerRadius="8" Background="{DynamicResource BgCardBrush}" Padding="16"
                            Margin="0 16 0 0"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="📈 Resumen del período"
                                       FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0 0 0 12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0 0 0 12">
                                    <TextBlock Text="💰 Máquinas" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="LblResumenMaquinas" Text="S/ 0.00" FontSize="16" FontWeight="Bold" Foreground="#F59E0B"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="0">
                                    <TextBlock Text="🛒 Productos" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="LblResumenProductos" Text="S/ 0.00" FontSize="16" FontWeight="Bold" Foreground="#01EFAC"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="0">
                                    <TextBlock Text="💳 Yape" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="LblResumenYape" Text="S/ 0.00" FontSize="16" FontWeight="Bold" Foreground="#2082A6"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="0">
                                    <TextBlock Text="🧾 Efectivo" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="LblResumenEfectivo" Text="S/ 0.00" FontSize="16" FontWeight="Bold" Foreground="#01EFAC"/>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Grid.Row="1">
                                    <TextBlock Text="📊 Transacciones" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="LblResumenTransacciones" Text="0" FontSize="16" FontWeight="Bold" Foreground="#524094"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Grid.Row="1">
                                    <TextBlock Text="📦 Prod. Vendidos" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="LblResumenProdVendidos" Text="0" FontSize="16" FontWeight="Bold" Foreground="#524094"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Grid.Row="1">
                                    <TextBlock Text="📉 Descuentos" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="LblResumenDescuentos" Text="S/ 0.00" FontSize="16" FontWeight="Bold" Foreground="#EF4444"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Grid.Row="1">
                                    <TextBlock Text="🏆 Total Líquido" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="LblResumenLiquido" Text="S/ 0.00" FontSize="16" FontWeight="Bold" Foreground="#01EFAC"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
