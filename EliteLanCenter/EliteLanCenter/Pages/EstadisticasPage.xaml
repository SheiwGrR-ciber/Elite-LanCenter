<Page x:Class="EliteLanCenter.Pages.EstadisticasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Background="#111827"
      FontFamily="{StaticResource InterFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0 0 0 20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Estadísticas"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#E8EAF6"/>
                <TextBlock x:Name="LblPeriodo"
                           Text="Datos de los últimos 7 días"
                           FontSize="13"
                           Foreground="#8892B0"
                           Margin="0 4 0 0"/>
            </StackPanel>

            <!-- Filtros de período -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="Btn7Dias"
                        Content="7 Días"
                        Style="{StaticResource AccentButton}"
                        Click="BtnFiltro_Click"
                        Tag="7"
                        Margin="0 0 8 0"/>
                <Button x:Name="Btn30Dias"
                        Content="30 Días"
                        Click="BtnFiltro_Click"
                        Tag="30"
                        Margin="0 0 8 0"/>
                <Button x:Name="BtnEsteMes"
                        Content="Este Mes"
                        Click="BtnFiltro_Click"
                        Tag="mes"
                        Margin="0 0 8 0"/>
            </StackPanel>
        </Grid>

        <!-- Resumen Cards -->
        <Grid Grid.Row="1" Margin="0 0 0 20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="12" Background="#1A1F35" Padding="16" Margin="0 0 8 0">
                <StackPanel>
                    <TextBlock Text="💰" FontSize="20"/>
                    <TextBlock Text="Ventas Totales"
                               FontSize="11" Foreground="#8892B0" Margin="0 8 0 4"/>
                    <TextBlock x:Name="LblVentasTotales"
                               Text="S/ 0.00"
                               FontSize="18" FontWeight="Bold" Foreground="#01EFAC"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" CornerRadius="12" Background="#1A1F35" Padding="16" Margin="8 0">
                <StackPanel>
                    <TextBlock Text="📊" FontSize="20"/>
                    <TextBlock Text="Transacciones"
                               FontSize="11" Foreground="#8892B0" Margin="0 8 0 4"/>
                    <TextBlock x:Name="LblTransacciones"
                               Text="0"
                               FontSize="18" FontWeight="Bold" Foreground="#524094"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" CornerRadius="12" Background="#1A1F35" Padding="16" Margin="8 0">
                <StackPanel>
                    <TextBlock Text="💳" FontSize="20"/>
                    <TextBlock Text="Yape/Transfer."
                               FontSize="11" Foreground="#8892B0" Margin="0 8 0 4"/>
                    <TextBlock x:Name="LblYapeTotal"
                               Text="S/ 0.00"
                               FontSize="18" FontWeight="Bold" Foreground="#2082A6"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" CornerRadius="12" Background="#1A1F35" Padding="16" Margin="8 0 0 0">
                <StackPanel>
                    <TextBlock Text="🎰" FontSize="20"/>
                    <TextBlock Text="Máquinas"
                               FontSize="11" Foreground="#8892B0" Margin="0 8 0 4"/>
                    <TextBlock x:Name="LblMaquinasTotal"
                               Text="S/ 0.00"
                               FontSize="18" FontWeight="Bold" Foreground="#F59E0B"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Gráficos -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Gráfico de ventas por día -->
            <Border Grid.Column="0" Grid.Row="0" CornerRadius="12" Background="#1A1F35" Margin="0 0 8 8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="📈 Ventas por Día"
                               FontSize="14" FontWeight="SemiBold" Foreground="#E8EAF6"
                               Margin="16 16 16 8"/>
                    <lvc:CartesianChart Grid.Row="1"
                                        x:Name="GraficoVentasDiarias"
                                        Margin="8"/>
                </Grid>
            </Border>

            <!-- Gráfico de ingresos por turno -->
            <Border Grid.Column="1" Grid.Row="0" CornerRadius="12" Background="#1A1F35" Margin="8 0 0 8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🕐 Ingresos por Turno"
                               FontSize="14" FontWeight="SemiBold" Foreground="#E8EAF6"
                               Margin="16 16 16 8"/>
                    <lvc:PieChart Grid.Row="1"
                                  x:Name="GraficoTurnos"
                                  Margin="8"/>
                </Grid>
            </Border>

            <!-- Gráfico de productos más vendidos -->
            <Border Grid.Column="0" Grid.Row="1" CornerRadius="12" Background="#1A1F35" Margin="0 8 8 0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🏆 Productos Más Vendidos"
                               FontSize="14" FontWeight="SemiBold" Foreground="#E8EAF6"
                               Margin="16 16 16 8"/>
                    <lvc:CartesianChart Grid.Row="1"
                                        x:Name="GraficoProductos"
                                        Margin="8"/>
                </Grid>
            </Border>

            <!-- Resumen semanal detallado -->
            <Border Grid.Column="1" Grid.Row="1" CornerRadius="12" Background="#1A1F35" Margin="8 8 0 0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="📋 Resumen Semanal"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#E8EAF6"
                                   Margin="0 0 0 16"/>

                        <Border CornerRadius="8" Background="#2D3250" Padding="12" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Efectivo" Foreground="#8892B0" FontSize="12"/>
                                <TextBlock Grid.Column="1" x:Name="LblEfectivoTotal" Text="S/ 0.00" FontSize="14" FontWeight="Bold" Foreground="#01EFAC"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="8" Background="#2D3250" Padding="12" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Descuentos" Foreground="#8892B0" FontSize="12"/>
                                <TextBlock Grid.Column="1" x:Name="LblDescuentosTotal" Text="S/ 0.00" FontSize="14" FontWeight="Bold" Foreground="#EF4444"/>
                            </Grid>
                        </Border>

                        <Border CornerRadius="8" Background="#2D3250" Padding="12" Margin="0 0 0 8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Líquido" Foreground="#8892B0" FontSize="12"/>
                                <TextBlock Grid.Column="1" x:Name="LblLiquidoTotal" Text="S/ 0.00" FontSize="14" FontWeight="Bold" Foreground="#01EFAC"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="───────── Detalle por Día ─────────"
                                   FontSize="11" Foreground="#2D3250"
                                   HorizontalAlignment="Center" Margin="0 16 0 8"/>

                        <ItemsControl x:Name="ListaDias">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Background="#1A1F35" Padding="10" Margin="0 0 0 4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Fecha}" Foreground="#E8EAF6" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Ventas}" Foreground="#01EFAC" FontSize="12" Margin="8 0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Transacciones}" Foreground="#8892B0" FontSize="11" Width="50" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
