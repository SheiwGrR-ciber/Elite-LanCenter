<Page x:Class="EliteLanCenter.Pages.TurnosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#111827"
      FontFamily="{StaticResource InterFont}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- ── Turno activo ───────────────── -->
            <Border CornerRadius="12" Padding="20"
                    Margin="0 0 0 16" Background="#1A1F35">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Info turno -->
                    <Grid Grid.Row="0" Margin="0 0 0 16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="LblTurnoActivo"
                                       Text="⚠ No hay turno abierto"
                                       FontFamily="{StaticResource MontserratFont}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#F59E0B"/>
                            <TextBlock x:Name="LblInfoTurno"
                                       Text="—"
                                       FontSize="12"
                                       Foreground="#8892B0"
                                       Margin="0 4 0 0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                x:Name="BtnCerrarTurno"
                                Content="🔒  Cerrar Turno"
                                Style="{StaticResource DangerButton}"
                                Width="150"
                                Visibility="Collapsed"
                                Click="BtnCerrarTurno_Click"/>
                    </Grid>

                    <!-- Stock mostrador -->
                    <Border Grid.Row="1" CornerRadius="8"
                            Background="#111827" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Stock actual en el mostrador"
                                       FontFamily="{StaticResource MontserratFont}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#E8EAF6"
                                       Margin="0 0 0 12"/>

                            <!-- Encabezado tabla -->
                            <Border CornerRadius="6" Padding="12 8"
                                    Background="#2D3250" Margin="0 0 0 4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Producto"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#8892B0"/>
                                    <TextBlock Grid.Column="1" Text="Stock"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#8892B0"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Valor"
                                               FontSize="11" FontWeight="Bold"
                                               Foreground="#8892B0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>

                            <!-- Lista productos -->
                            <ItemsControl x:Name="ListaStock">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12 8"
                                                BorderThickness="0 0 0 1">
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="#2D3250"
                                                                 Opacity="0.3"/>
                                            </Border.BorderBrush>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Nombre}"
                                                           FontSize="13"
                                                           Foreground="#E8EAF6"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding StockMostrador}"
                                                           FontSize="13"
                                                           Foreground="#01CBAE"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding ValorMostrador, StringFormat='S/ {0:F2}'}"
                                                           FontSize="13"
                                                           Foreground="#8892B0"
                                                           HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Total -->
                            <Border Padding="12 8" CornerRadius="6"
                                    Background="#2D3250" Margin="0 8 0 0">
                                <Grid>
                                    <TextBlock Text="Total en mostrador:"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#8892B0"/>
                                    <TextBlock x:Name="LblTotalMostrador"
                                               Text="S/ 0.00"
                                               FontFamily="{StaticResource MontserratFont}"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="#01EFAC"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Semana actual ──────────────── -->
            <Border CornerRadius="12" Padding="20"
                    Background="#1A1F35">
                <StackPanel>
                    <TextBlock Text="SEMANA ACTUAL"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#2D3250"
                               Margin="0 0 0 12"/>

                    <ItemsControl x:Name="ListaSemana">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Padding="12"
                                        Margin="0 4" Background="#111827">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Día -->
                                        <StackPanel Grid.Column="0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DiaNombre}"
                                                       FontFamily="{StaticResource MontserratFont}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#E8EAF6"/>
                                            <TextBlock Text="{Binding Fecha}"
                                                       FontSize="11"
                                                       Foreground="#8892B0"/>
                                        </StackPanel>

                                        <!-- Mañana -->
                                        <Border Grid.Column="1"
                                                CornerRadius="6" Padding="8"
                                                Margin="4 0" Background="#1A1F35">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="🌅 Mañana"
                                                           FontSize="11"
                                                           Foreground="#8892B0"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding EstadoManana}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding ColorManana}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0 4 0 0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Tarde -->
                                        <Border Grid.Column="2"
                                                CornerRadius="6" Padding="8"
                                                Margin="4 0" Background="#1A1F35">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="🌤️ Tarde"
                                                           FontSize="11"
                                                           Foreground="#8892B0"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding EstadoTarde}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding ColorTarde}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0 4 0 0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Noche -->
                                        <Border Grid.Column="3"
                                                CornerRadius="6" Padding="8"
                                                Margin="4 0" Background="#1A1F35">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="🌙 Noche"
                                                           FontSize="11"
                                                           Foreground="#8892B0"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding EstadoNoche}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding ColorNoche}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0 4 0 0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>