<Application x:Class="EliteLanCenter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/LoginView.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!-- Material Design -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml"/>

                <!-- Temas Aurora Boreal -->
                <ResourceDictionary Source="/Themes/ColorsTheme.xaml"/>
                <ResourceDictionary Source="/Themes/StylesTheme.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <!-- Fuentes personalizadas -->
            <FontFamily x:Key="MontserratFont">
                pack://application:,,,/Assets/Montserrat-VariableFont_wght.ttf#Montserrat
            </FontFamily>
            <FontFamily x:Key="InterFont">
                pack://application:,,,/Assets/Inter-VariableFont_opsz,wght.ttf#Inter
            </FontFamily>

            <!-- Converters -->
            <helpers:BoolToRFIDConverter x:Key="BoolToRFIDConverter"
                                        xmlns:helpers="clr-namespace:EliteLanCenter.Helpers"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>