<Window x:Class="EliteLanCenter.Views.TrasladoStockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trasladar a Mostrador"
        Width="400"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgPrincipalBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0 0 0 20">
            <TextBlock Text="Trasladar a Mostrador"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock x:Name="LblProducto"
                       FontSize="13"
                       Foreground="#01EFAC"
                       Margin="0 8 0 0"/>
            <TextBlock x:Name="LblStockActual"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0 4 0 0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Paquetes a trasladar" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="{DynamicResource BgCardBrush}" Margin="0 0 0 12">
                <TextBox x:Name="TxtPaquetes"
                         Height="40"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         CaretBrush="#01EFAC"
                         FontSize="13"
                         Padding="12 0"
                         VerticalContentAlignment="Center"
                         Text="0"/>
            </Border>

            <TextBlock Text="Unidades sueltas a trasladar" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="{DynamicResource BgCardBrush}" Margin="0 0 0 12">
                <TextBox x:Name="TxtUnidades"
                         Height="40"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         CaretBrush="#01EFAC"
                         FontSize="13"
                         Padding="12 0"
                         VerticalContentAlignment="Center"
                         Text="0"/>
            </Border>

            <TextBlock x:Name="LblError"
                       FontSize="12"
                       Foreground="#EF4444"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="100"
                    Height="36"
                    Background="{DynamicResource BgCardBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"
                    Click="BtnCancelar_Click"
                    Margin="0 0 8 0"/>
            <Button Content="Trasladar"
                    Width="100"
                    Height="36"
                    Background="#01EFAC"
                    Foreground="#111827"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="BtnTrasladar_Click"/>
        </StackPanel>
    </Grid>
</Window>
