<Window x:Class="EliteLanCenter.Views.ProductoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Producto"
        Width="420"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111827">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="LblTitulo"
                   Text="Nuevo Producto"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#E8EAF6"
                   Margin="0 0 0 20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Nombre del producto *" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                <TextBox x:Name="TxtNombre"
                         Height="40"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E8EAF6"
                         CaretBrush="#01EFAC"
                         FontSize="13"
                         Padding="12 0"
                         VerticalContentAlignment="Center"/>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Precio Unitario (S/) *" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
                    <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                        <TextBox x:Name="TxtPrecioUnidad"
                                 Height="40"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#E8EAF6"
                                 CaretBrush="#01EFAC"
                                 FontSize="13"
                                 Padding="12 0"
                                 VerticalContentAlignment="Center"
                                 Text="0.00"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Precio Paquete (S/)" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
                    <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                        <TextBox x:Name="TxtPrecioPaquete"
                                 Height="40"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#E8EAF6"
                                 CaretBrush="#01EFAC"
                                 FontSize="13"
                                 Padding="12 0"
                                 VerticalContentAlignment="Center"
                                 Text="0.00"/>
                    </Border>
                </StackPanel>
            </Grid>

            <TextBlock Text="Unidades por paquete *" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                <TextBox x:Name="TxtUnidadesPaquete"
                         Height="40"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E8EAF6"
                         CaretBrush="#01EFAC"
                         FontSize="13"
                         Padding="12 0"
                         VerticalContentAlignment="Center"
                         Text="12"/>
            </Border>

            <TextBlock x:Name="LblError"
                       FontSize="12"
                       Foreground="#EF4444"
                       TextWrapping="Wrap"
                       Margin="0 0 0 8"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="100"
                    Height="36"
                    Background="#2D3250"
                    Foreground="#E8EAF6"
                    BorderThickness="0"
                    Click="BtnCancelar_Click"
                    Margin="0 0 8 0"/>
            <Button Content="Guardar"
                    Width="100"
                    Height="36"
                    Background="#01EFAC"
                    Foreground="#111827"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>
