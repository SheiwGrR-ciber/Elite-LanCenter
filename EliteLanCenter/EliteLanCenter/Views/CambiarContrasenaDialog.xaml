<Window x:Class="EliteLanCenter.Views.CambiarContrasenaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cambiar Contraseña"
        Width="400"
        Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111827">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0 0 0 20">
            <TextBlock Text="Cambiar Contraseña"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#E8EAF6"/>
            <TextBlock x:Name="LblUsuario"
                       FontSize="13"
                       Foreground="#01EFAC"
                       Margin="0 8 0 0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Nueva contraseña *" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 8">
                <PasswordBox x:Name="TxtContrasena"
                             Height="40"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E8EAF6"
                             CaretBrush="#01EFAC"
                             FontSize="13"
                             Padding="12 0"
                             VerticalContentAlignment="Center"
                             PasswordChanged="TxtContrasena_PasswordChanged"/>
            </Border>

            <TextBlock Text="Confirmar contraseña *" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                <PasswordBox x:Name="TxtConfirmar"
                             Height="40"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E8EAF6"
                             CaretBrush="#01EFAC"
                             FontSize="13"
                             Padding="12 0"
                             VerticalContentAlignment="Center"/>
            </Border>

            <!-- Barra de progreso -->
            <Border CornerRadius="4" Background="#2D3250" Margin="0 0 0 8">
                <Grid Height="8" Margin="8 4">
                    <Border x:Name="BarraProgreso" CornerRadius="2" Background="#EF4444" Width="0"/>
                </Grid>
            </Border>
            <TextBlock x:Name="LblFortaleza"
                       Text="Fortaleza: "
                       FontSize="11"
                       Foreground="#8892B0"
                       Margin="0 0 0 12"/>

            <!-- Requisitos -->
            <Border CornerRadius="8" Background="#1A1F35" Padding="12" Margin="0 0 0 8">
                <StackPanel>
                    <TextBlock Text="La contraseña debe tener:"
                               FontSize="11" Foreground="#8892B0" Margin="0 0 0 8"/>
                    <TextBlock x:Name="LblReq1" Text="✗ Mínimo 8 caracteres" FontSize="11" Foreground="#8892B0"/>
                    <TextBlock x:Name="LblReq2" Text="✗ Al menos una mayúscula" FontSize="11" Foreground="#8892B0"/>
                    <TextBlock x:Name="LblReq3" Text="✗ Al menos una minúscula" FontSize="11" Foreground="#8892B0"/>
                    <TextBlock x:Name="LblReq4" Text="✗ Al menos un número" FontSize="11" Foreground="#8892B0"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="LblError"
                       FontSize="12"
                       Foreground="#EF4444"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 16 0 0">
            <Button Content="Cancelar"
                    Width="100"
                    Height="36"
                    Background="#2D3250"
                    Foreground="#E8EAF6"
                    BorderThickness="0"
                    Click="BtnCancelar_Click"
                    Margin="0 0 8 0"/>
            <Button Content="Cambiar"
                    Width="100"
                    Height="36"
                    Background="#01EFAC"
                    Foreground="#111827"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="BtnCambiar_Click"/>
        </StackPanel>
    </Grid>
</Window>
