<Window x:Class="EliteLanCenter.Views.UsuarioDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Usuario"
        Width="420"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111827">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="LblTitulo"
                   Text="Nuevo Usuario"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#E8EAF6"
                   Margin="0 0 0 20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Nombre completo *" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
                <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                    <TextBox x:Name="TxtNombre"
                             Height="40"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E8EAF6"
                             CaretBrush="#01EFAC"
                             FontSize="13"
                             Padding="12 0"
                             VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock Text="Nombre de usuario *" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
                <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                    <TextBox x:Name="TxtUserName"
                             Height="40"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#E8EAF6"
                             CaretBrush="#01EFAC"
                             FontSize="13"
                             Padding="12 0"
                             VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock x:Name="LblContrasenaTexto"
                           Text="Contraseña *"
                           FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
                <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                    <PasswordBox x:Name="TxtContrasena"
                                 Height="40"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#E8EAF6"
                                 FontSize="13"
                                 Padding="12 0"
                                 VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock Text="Rol *" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
                <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                    <ComboBox x:Name="CmbRol"
                              Height="40"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="#E8EAF6"
                              FontSize="13"
                              Padding="12 0"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Administrador Dueño" Tag="AdminDueno" IsSelected="True"/>
                        <ComboBoxItem Content="Administrador Encargado" Tag="AdminEncargado"/>
                        <ComboBoxItem Content="Operador" Tag="Operador"/>
                    </ComboBox>
                </Border>

                <!-- Requisitos de contraseña -->
                <Border CornerRadius="8" Background="#1A1F35" Padding="12" Margin="0 0 0 8">
                    <StackPanel>
                        <TextBlock Text="La contraseña debe tener:"
                                   FontSize="11" Foreground="#8892B0" Margin="0 0 0 8"/>
                        <TextBlock x:Name="LblReq1" Text="✓ Mínimo 8 caracteres" FontSize="11" Foreground="#8892B0"/>
                        <TextBlock x:Name="LblReq2" Text="✓ Al menos una mayúscula" FontSize="11" Foreground="#8892B0"/>
                        <TextBlock x:Name="LblReq3" Text="✓ Al menos una minúscula" FontSize="11" Foreground="#8892B0"/>
                        <TextBlock x:Name="LblReq4" Text="✓ Al menos un número" FontSize="11" Foreground="#8892B0"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="LblError"
                           FontSize="12"
                           Foreground="#EF4444"
                           TextWrapping="Wrap"
                           Margin="0 0 0 8"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 16 0 0">
            <Button Content="Cancelar"
                    Width="100"
                    Height="36"
                    Background="#2D3250"
                    Foreground="#E8EAF6"
                    BorderThickness="0"
                    Click="BtnCancelar_Click"
                    Margin="0 0 8 0"/>
            <Button Content="Guardar"
                    Width="100"
                    Height="36"
                    Background="#01EFAC"
                    Foreground="#111827"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>
