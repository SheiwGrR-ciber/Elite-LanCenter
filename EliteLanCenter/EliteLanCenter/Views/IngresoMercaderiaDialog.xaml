<Window x:Class="EliteLanCenter.Views.IngresoMercaderiaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ingresar Mercadería"
        Width="440"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgPrincipalBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Ingresar Mercadería"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0 0 0 20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Producto *" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="{DynamicResource BgCardBrush}" Margin="0 0 0 16">
                <ComboBox x:Name="CmbProducto"
                          Height="40"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          FontSize="13"
                          Padding="8 0"
                          DisplayMemberPath="Nombre"
                          SelectedValuePath="Id"/>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Paquetes" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
                    <Border CornerRadius="8" Background="{DynamicResource BgCardBrush}" Margin="0 0 0 16">
                        <TextBox x:Name="TxtPaquetes"
                                 Height="40"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="#01EFAC"
                                 FontSize="13"
                                 Padding="12 0"
                                 VerticalContentAlignment="Center"
                                 Text="0"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Unidades Sueltas" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
                    <Border CornerRadius="8" Background="{DynamicResource BgCardBrush}" Margin="0 0 0 16">
                        <TextBox x:Name="TxtUnidades"
                                 Height="40"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                 CaretBrush="#01EFAC"
                                 FontSize="13"
                                 Padding="12 0"
                                 VerticalContentAlignment="Center"
                                 Text="0"/>
                    </Border>
                </StackPanel>
            </Grid>

            <TextBlock Text="Costo Total (S/)" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="{DynamicResource BgCardBrush}" Margin="0 0 0 8">
                <TextBox x:Name="TxtCostoTotal"
                         Height="40"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         CaretBrush="#01EFAC"
                         FontSize="13"
                         Padding="12 0"
                         VerticalContentAlignment="Center"
                         Text="0.00"/>
            </Border>

            <TextBlock x:Name="LblError"
                       FontSize="12"
                       Foreground="#EF4444"
                       TextWrapping="Wrap"
                       Margin="0 8 0 0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="100"
                    Height="36"
                    Background="{DynamicResource BgCardBrush}"
                    Foreground="{DynamicResource TextPrimaryBrush}"
                    BorderThickness="0"
                    Click="BtnCancelar_Click"
                    Margin="0 0 8 0"/>
            <Button Content="Ingresar"
                    Width="100"
                    Height="36"
                    Background="#01EFAC"
                    Foreground="#111827"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="BtnIngresar_Click"/>
        </StackPanel>
    </Grid>
</Window>
