<Window x:Class="EliteLanCenter.Views.NuevoCaseroView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nuevo Casero"
        Width="420"
        Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111827">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Nuevo Casero"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#E8EAF6"
                   Margin="0 0 0 20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Nombre *" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                <TextBox x:Name="TxtNombre"
                         Height="40"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E8EAF6"
                         CaretBrush="#01EFAC"
                         FontSize="13"
                         Padding="12 0"
                         VerticalContentAlignment="Center"/>
            </Border>

            <TextBlock Text="Apodo" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                <TextBox x:Name="TxtApodo"
                         Height="40"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E8EAF6"
                         CaretBrush="#01EFAC"
                         FontSize="13"
                         Padding="12 0"
                         VerticalContentAlignment="Center"/>
            </Border>

            <TextBlock Text="Teléfono" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                <TextBox x:Name="TxtTelefono"
                         Height="40"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E8EAF6"
                         CaretBrush="#01EFAC"
                         FontSize="13"
                         Padding="12 0"
                         VerticalContentAlignment="Center"/>
            </Border>

            <TextBlock Text="Código RFID" FontSize="12" Foreground="#8892B0" Margin="0 0 0 4"/>
            <Border CornerRadius="8" Background="#2D3250" Margin="0 0 0 12">
                <TextBox x:Name="TxtRFID"
                         Height="40"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#E8EAF6"
                         CaretBrush="#01EFAC"
                         FontSize="13"
                         Padding="12 0"
                         VerticalContentAlignment="Center"/>
            </Border>

            <TextBlock x:Name="LblError"
                       FontSize="12"
                       Foreground="#EF4444"
                       TextWrapping="Wrap"
                       Margin="0 0 0 8"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="100"
                    Height="36"
                    Background="#2D3250"
                    Foreground="#E8EAF6"
                    BorderThickness="0"
                    Click="BtnCancelar_Click"
                    Margin="0 0 8 0"/>
            <Button Content="Guardar"
                    Width="100"
                    Height="36"
                    Background="#01EFAC"
                    Foreground="#111827"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Window>
