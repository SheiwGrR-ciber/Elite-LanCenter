<Window x:Class="EliteLanCenter.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elite LanCenter — Iniciar Sesión"
        Height="600" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BgPrincipalBrush}"
        FontFamily="{StaticResource InterFont}">

    <Grid>
        <!-- Barra lateral izquierda aurora -->
        <Rectangle Width="4" HorizontalAlignment="Left"
                   Fill="{DynamicResource AuroraGreenBrush}" Opacity="0.8"/>

        <!-- Contenido principal -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="320">

            <!-- Logo e icono -->
            <Border Width="80" Height="80"
                    CornerRadius="20"
                    Margin="0 0 0 16"
                    HorizontalAlignment="Center">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#524094" Offset="0"/>
                        <GradientStop Color="#562A83" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="🖥️"
                           FontSize="36"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Título -->
            <TextBlock Text="ELITE"
                       FontFamily="{StaticResource MontserratFont}"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AuroraGreenBrush}"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="LAN CENTER"
                       FontFamily="{StaticResource MontserratFont}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 8"/>

            <TextBlock Text="Sistema de Gestión Administrativa"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 32"/>

            <!-- Card del formulario -->
            <Border CornerRadius="16"
                    Padding="24"
                    Margin="0 0 0 0"
                    Background="{DynamicResource BgPanelBrush}">

                <StackPanel>

                    <!-- Campo Usuario -->
                    <TextBlock Text="Usuario"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0 0 0 6"/>

                    <Border CornerRadius="8"
                            BorderThickness="1"
                            Margin="0 0 0 16"
                            BorderBrush="{DynamicResource BorderBrush}"
                            x:Name="BorderUsuario">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="👤"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     x:Name="TxtUsuario"
                                     Height="42"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource AuroraGreenBrush}"
                                     FontSize="13"
                                     VerticalContentAlignment="Center"
                                     KeyDown="TxtUsuario_KeyDown"/>
                        </Grid>
                    </Border>

                    <!-- Campo Contraseña -->
                    <TextBlock Text="Contraseña"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0 0 0 6"/>

                    <Border CornerRadius="8"
                            BorderThickness="1"
                            Margin="0 0 0 24"
                            BorderBrush="{DynamicResource BorderBrush}"
                            x:Name="BorderContrasena">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="🔒"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <PasswordBox Grid.Column="1"
                                         x:Name="TxtContrasena"
                                         Height="42"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         FontSize="13"
                                         VerticalContentAlignment="Center"
                                         KeyDown="TxtContrasena_KeyDown"/>
                        </Grid>
                    </Border>

                    <!-- Mensaje de error -->
                    <TextBlock x:Name="LblError"
                               Text=""
                               FontSize="12"
                               Foreground="{DynamicResource ErrorBrush}"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 16"
                               TextWrapping="Wrap"/>

                    <!-- Botón Ingresar -->
                    <Button x:Name="BtnIngresar"
                            Content="Ingresar al Sistema"
                            Height="46"
                            FontFamily="{StaticResource MontserratFont}"
                            FontWeight="SemiBold"
                            FontSize="14"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnIngresar_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#524094" Offset="0"/>
                                <GradientStop Color="#2082A6" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Border>

            <!-- Version -->
            <TextBlock Text="v2.0.0 — Elite LanCenter"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0 16 0 0"/>

        </StackPanel>
    </Grid>
</Window>
